NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: read protected tables from API routes without a browser session (e.g. GET /api/scrape/promo-watchlist).
# Supabase Dashboard → Project Settings → API → service_role (secret). Must differ from NEXT_PUBLIC_SUPABASE_ANON_KEY.
# Never commit or expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret for machine callers (Bearer). Must match SCRAPE_SYNC_SECRET in apps/playwright-tools/.env
SCRAPE_SYNC_SECRET=

# Optional: worker base URL for "Extract now" and "Fetch video info" (e.g. http://localhost:8787 when running worker locally)
GROWING_WORKER_URL=

# --- Public shared cookbook (/cookbook) — optional ---
# Without these, signed-in users can still preview /cookbook (their own recipes via RLS). Anonymous visitors need both:
# Supabase user id (auth.users.id) whose saved_recipes are listed publicly. Find in Supabase Auth or your profile.
COOKBOOK_PUBLIC_USER_ID=
# Same service role as above; required for anonymous access to /cookbook (scoped to COOKBOOK_PUBLIC_USER_ID only).
# NEXT_PUBLIC_COOKBOOK_TITLE=Shared cookbook
# NEXT_PUBLIC_COOKBOOK_SUBTITLE=Browse and cook
# NEXT_PUBLIC_COOKBOOK_FEEDBACK_EMAIL=you@example.com
