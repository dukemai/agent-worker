{
  "$schema": "https://turbo.build/schema.json",
  "pipeline": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dashboard:build": {
      "dependsOn": ["^dashboard:build"],
      "outputs": [".next/**", "dist/**", "apps/dasboard/.next/**"]
    },
    "lint": {
      "cache": true
    },
    "test": {
      "cache": true
    }
  }
}

