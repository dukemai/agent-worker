{
  "name": "cloudflare-email-worker",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "workspaces": [
    ".",
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "test:fixture": "./scripts/test-fixture.sh",
    "dashboard:dev": "pnpm --filter dashboard dev",
    "dashboard:build": "pnpm --filter dashboard build",
    "dev:all": "pnpm turbo run dev --parallel",
    "build:all": "pnpm turbo run build",
    "lint:all": "pnpm turbo run lint --parallel",
    "playwright:test": "pnpm --filter @agent/playwright-tools test",
    "playwright:match-rules": "pnpm --filter @agent/playwright-tools test:match-rules",
    "playwright:ui": "pnpm --filter @agent/playwright-tools test:ui",
    "playwright:install": "pnpm --filter @agent/playwright-tools exec playwright install chromium",
    "promo:download-watchlist": "pnpm --filter @agent/playwright-tools download-watchlist",
    "promo:scrape:ica-maxi-barkarbystaden": "pnpm --filter @agent/playwright-tools scrape:ica-maxi-barkarbystaden",
    "promo:scrape:ica-nara-kallhall": "pnpm --filter @agent/playwright-tools scrape:ica-nara-kallhall",
    "promo:scrape:coop-kallhall": "pnpm --filter @agent/playwright-tools scrape:coop-kallhall",
    "promo:picker-catalog": "node scripts/build-ica-maxi-promo-picker-catalog.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "next": "16.1.6",
    "turbo": "^2.8.11",
    "typescript": "^5.5.0",
    "wrangler": "^3.91.0"
  },
  "dependencies": {
    "@agent/shared": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.47.0",
    "@react-email/components": "^1.0.9",
    "@react-email/render": "^2.0.4",
    "postal-mime": "^2.7.3",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  }
}
